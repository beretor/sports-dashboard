# Copie ce fichier en .env pour le développement local
# Ne committe JAMAIS .env dans Git

# ── Strava ────────────────────────────────────────────────────────────────────
# Disponibles sur https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Obtenu via : python scripts/strava_auth.py
STRAVA_REFRESH_TOKEN=your_refresh_token

# ── Garmin Connect ────────────────────────────────────────────────────────────
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Disponible sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
